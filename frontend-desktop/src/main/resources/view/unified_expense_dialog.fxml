<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.UnifiedExpenseDialogController"
      prefHeight="580" prefWidth="920" spacing="0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="dialog-header-bar">
        <Label styleClass="dialog-header-title" text="%unified_expense.title"/>
    </HBox>

    <TabPane fx:id="modeTabPane" styleClass="dialog-tab-pane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <Tab text="%unified_expense.tab.daily">
                <VBox spacing="18" styleClass="dialog-body">
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" prefWidth="250" spacing="6">
                            <Label styleClass="field-label" text="%unified_expense.daily.category"/>
                            <ComboBox fx:id="comboCategory" maxWidth="Infinity" styleClass="form-control-tall"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="6">
                            <Label styleClass="muted-label" text="Bağlı Sabit Gider (Opsiyonel)"/>
                            <ComboBox fx:id="comboLinkedFixedExpense" maxWidth="Infinity"
                                      promptText="Sabit gidere bağla..." styleClass="form-control-tall"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="16">
                        <VBox HBox.hgrow="ALWAYS" spacing="6">
                            <Label styleClass="field-label" text="%unified_expense.daily.amount"/>
                            <CurrencyTextField fx:id="txtAmount" promptText="0,00" styleClass="form-control-tall"/>
                        </VBox>
                        <VBox HBox.hgrow="ALWAYS" spacing="6">
                            <Label styleClass="field-label" text="%unified_expense.daily.date"/>
                            <DatePicker fx:id="datePicker" maxWidth="Infinity" styleClass="form-control-tall"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="6" VBox.vgrow="ALWAYS">
                        <Label styleClass="field-label" text="%unified_expense.daily.description"/>
                        <TextArea fx:id="txtDescription" prefRowCount="4" promptText="%unified_expense.daily.description_prompt"
                                  VBox.vgrow="ALWAYS"/>
                    </VBox>
                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Button onAction="#handleDailyCancel" styleClass="btn-secondary" text="%unified_expense.daily.cancel"/>
                        <Button onAction="#handleDailySave" styleClass="btn-success" text="%unified_expense.daily.save"/>
                    </HBox>
                </VBox>
            </Tab>
            <Tab text="%unified_expense.tab.fixed">
                <VBox spacing="12" styleClass="dialog-body-compact">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label styleClass="muted-label" text="%unified_expense.fixed.select_info"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label styleClass="field-label" text="%unified_expense.fixed.payment_date"/>
                        <DatePicker fx:id="dtFixedPaymentDate" prefWidth="150"/>
                    </HBox>
                    <TableView fx:id="fixedExpensesTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colFixedSelect" prefWidth="50.0" text=""/>
                            <TableColumn fx:id="colFixedName" prefWidth="160.0" text="%finance.pay_fixed_expense_dialog.name"/>
                            <TableColumn fx:id="colFixedCategory" prefWidth="100.0" text="%fixed_expense.category"/>
                            <TableColumn fx:id="colFixedFrequency" prefWidth="80.0" text="Sıklık"/>
                            <TableColumn fx:id="colFixedAmount" prefWidth="90.0" text="Varsayılan"/>
                            <TableColumn fx:id="colFixedPayAmount" prefWidth="100.0" text="Ödeme Tutarı"/>
                            <TableColumn fx:id="colFixedLinkedInfo" prefWidth="180.0" text="Bağlı Ödeme"/>
                            <TableColumn fx:id="colFixedDayOfMonth" prefWidth="60.0" text="%fixed_expense.day_of_month"/>
                            <TableColumn fx:id="colFixedDaysUntil" prefWidth="80.0" text="%finance.pay_fixed_expense_dialog.days_until"/>
                            <TableColumn fx:id="colFixedStatus" prefWidth="80.0" text="%finance.pay_fixed_expense_dialog.status"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Button onAction="#handleFixedCancel" styleClass="btn-secondary" text="%unified_expense.fixed.cancel"/>
                        <Button onAction="#handleFixedPay" styleClass="btn-success" text="%unified_expense.fixed.pay_selected"/>
                    </HBox>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
