<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pusula.desktop.controller.BalanceEditDialogController"
      spacing="15" style="-fx-padding: 20;">

    <Label text="%currentaccount.balance.edit.title" styleClass="dialog-title">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
    </Label>

    <Separator />

    <!-- Current Balance Display -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="%currentaccount.balance.current" />
        <Label fx:id="currentBalanceLabel" text="₺0.00" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
    </HBox>

    <!-- Operation Type Selection -->
    <VBox spacing="8">
        <Label text="%currentaccount.balance.operation" />
        <ComboBox fx:id="operationCombo" maxWidth="Infinity" promptText="Seçiniz..." />
    </VBox>

    <!-- Amount Input -->
    <VBox spacing="8">
        <Label text="%currentaccount.balance.amount" />
        <CurrencyTextField fx:id="amountField" promptText="0,00" />
    </VBox>

    <!-- Note/Description -->
    <VBox spacing="8">
        <Label text="%table.notes" />
        <TextArea fx:id="noteField" prefRowCount="3" promptText="İşlem açıklaması (opsiyonel)" />
    </VBox>

    <!-- New Balance Preview -->
    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f0f0f0; -fx-padding: 10; -fx-border-radius: 5; -fx-background-radius: 5;">
        <Label text="%currentaccount.balance.new" />
        <Label fx:id="newBalanceLabel" text="₺0.00" style="-fx-font-weight: bold; -fx-font-size: 16px; -fx-text-fill: #2196F3;" />
    </HBox>

    <!-- Action Buttons -->
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="%button.cancel" onAction="#handleCancel" styleClass="secondary-button" />
        <Button text="%button.save" onAction="#handleSave" styleClass="primary-button" />
    </HBox>

</VBox>
