<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.UserDialogController"
      prefHeight="400" prefWidth="400" spacing="15" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <Label styleClass="dialog-title" text="%settings.add_user"/>

    <GridPane hgap="10" vgap="12">
        <columnConstraints>
            <ColumnConstraints hgrow="NEVER" minWidth="100"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label" text="%settings.username"/>
        <TextField fx:id="txtUsername" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label" text="%settings.full_name"/>
        <TextField fx:id="txtFullName" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label fx:id="lblPassword" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label" text="%settings.password"/>
        <PasswordField fx:id="txtPassword" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="field-label" text="%settings.role"/>
        <ComboBox fx:id="cmbRole" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label" text="%settings.signature"/>
        <HBox GridPane.columnIndex="1" GridPane.rowIndex="4" spacing="10">
            <Button fx:id="btnSelectSignature" onAction="#handleSelectSignature" styleClass="btn-secondary" text="%settings.select_signature"/>
            <Label fx:id="lblSignatureFilename" styleClass="label-filename" text=""/>
        </HBox>
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="%dialog.cancel"/>
        <Button onAction="#handleSave" styleClass="btn-success" text="%dialog.save"/>
    </HBox>
</VBox>
