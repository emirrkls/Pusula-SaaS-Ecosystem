<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pusula.desktop.controller.TicketDetailsController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Label text="%ticket.details.title">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label fx:id="lblStatus" text="STATUS" textFill="#7f8c8d">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnChangeStatus" mnemonicParsing="false" onAction="#handleChangeStatus" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="%ticket.change.status" visible="false" managed="false"/>
         </children>
      </HBox>
      
      <!-- Parent Ticket Link -->
      <Label fx:id="lblParentLink" managed="false" style="-fx-font-weight: bold; -fx-cursor: hand;" text="" textFill="#3498db" underline="true" visible="false" />
      
      <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
         <tabs>
            <Tab text="%ticket.tab.details">
               <content>
                  <VBox spacing="20.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="20.0" />
                     </padding>
                     <children>
                        <HBox spacing="20.0">
                           <children>
                              <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label text="%ticket.description" textFill="#7f8c8d" />
                                    <TextArea fx:id="txtDescription" editable="false" prefHeight="80.0" wrapText="true" />
                                    <Label text="%ticket.notes" textFill="#7f8c8d" />
                                    <TextArea fx:id="txtNotes" prefHeight="80.0" wrapText="true" />
                                    <Button mnemonicParsing="false" onAction="#handleSaveNotes" text="%ticket.save.notes" />
                                 </children>
                              </VBox>
                              
                              <VBox prefWidth="300.0" spacing="10.0">
                                 <children>
                                    <Label text="%ticket.assign.technician" textFill="#7f8c8d" />
                                    <HBox spacing="10.0">
                                       <children>
                                          <ComboBox fx:id="comboTechnician" prefWidth="200.0" promptText="%ticket.select.technician" />
                                          <Button minWidth="70.0" mnemonicParsing="false" onAction="#handleAssign" prefWidth="90.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="%btn.assign" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Label text="%ticket.used.parts">
                                       <font>
                                          <Font name="System Bold" size="18.0" />
                                       </font>
                                    </Label>
                                    <Button fx:id="btnAddPart" mnemonicParsing="false" onAction="#handleAddPart" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="%ticket.add.part" />
                                 </children>
                              </HBox>
                              <TableView fx:id="partsTable" VBox.vgrow="ALWAYS">
                                <columns>
                                  <TableColumn fx:id="colPartName" prefWidth="200.0" text="%ticket.part.name" />
                                  <TableColumn fx:id="colQuantity" prefWidth="100.0" text="%ticket.quantity" />
                                    <TableColumn fx:id="colPrice" prefWidth="100.0" text="%ticket.price" />
                                </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </Tab>
            <Tab text="%ticket.tab.history">
               <content>
                  <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                     <content>
                        <VBox fx:id="timelineContainer" spacing="15.0" style="-fx-background-color: #f5f5f5;">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                        </VBox>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>
         </tabs>
      </TabPane>
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="btnPrintPdf" onAction="#handlePrintPdf" prefWidth="120.0" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold;" text="%btn.print" />
            <Button fx:id="btnCreateRecall" managed="false" onAction="#handleCreateRecall" prefWidth="180.0" style="-fx-background-color: #ff9800; -fx-text-fill: white; -fx-font-weight: bold;" text="%ticket.recall" visible="false" />
            <Button fx:id="btnEditCompleted" managed="false" onAction="#handleEditCompleted" prefWidth="220.0" style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-weight: bold;" text="%btn.edit_completed" visible="false" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnCancelService" mnemonicParsing="false" onAction="#handleCancelService" prefWidth="150.0" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="%ticket.cancel" />
            <Button fx:id="btnCompleteService" mnemonicParsing="false" onAction="#handleCompleteService" prefWidth="150.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;" text="%ticket.complete" />
         </children>
      </HBox>
   </children>
</VBox>
