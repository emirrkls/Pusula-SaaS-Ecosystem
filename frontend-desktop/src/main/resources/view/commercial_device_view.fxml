<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.pusula.desktop.controller.CommercialDeviceViewController"
      spacing="15.0" style="-fx-background-color: #ecf0f1;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="%commercial.title">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAdd" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white;" text="%commercial.add">
            <font>
                <Font size="14.0" />
            </font>
        </Button>
    </HBox>

    <!-- Filter Bar -->
    <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
        <VBox spacing="5.0">
            <Label text="%commercial.device_type" textFill="#7f8c8d" />
            <ComboBox fx:id="cmbDeviceType" prefWidth="150.0" promptText="Tümü" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="%commercial.brand" textFill="#7f8c8d" />
            <ComboBox fx:id="cmbBrand" prefWidth="150.0" promptText="Tümü" />
        </VBox>
        <VBox spacing="5.0">
            <Label text="%commercial.btu" textFill="#7f8c8d" />
            <ComboBox fx:id="cmbBtu" prefWidth="120.0" promptText="Tümü" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleClearFilters" text="Filtreleri Temizle" />
    </HBox>

    <!-- Table -->
    <TableView fx:id="devicesTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white;">
        <columns>
            <TableColumn fx:id="colBrand" prefWidth="120.0" text="%commercial.brand" />
            <TableColumn fx:id="colModel" prefWidth="150.0" text="%commercial.model" />
            <TableColumn fx:id="colType" prefWidth="100.0" text="%commercial.device_type" />
            <TableColumn fx:id="colBtu" prefWidth="80.0" text="%commercial.btu" />
            <TableColumn fx:id="colGas" prefWidth="80.0" text="%commercial.gas" />
            <TableColumn fx:id="colQuantity" prefWidth="80.0" text="%commercial.quantity" />
            <TableColumn fx:id="colSellingPrice" prefWidth="100.0" text="%commercial.selling_price" />
            <TableColumn fx:id="colBuyingPrice" prefWidth="100.0" text="%commercial.buying_price" />
            <TableColumn fx:id="colProfit" prefWidth="100.0" text="%commercial.profit" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <!-- Action Buttons -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Button fx:id="btnEdit" onAction="#handleEdit" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="%commercial.edit" />
        <Button fx:id="btnDelete" onAction="#handleDelete" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="%commercial.delete" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnSell" onAction="#handleSell" style="-fx-background-color: #9b59b6; -fx-text-fill: white;" text="%commercial.sell" />
    </HBox>
</VBox>
