<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.ProposalViewController"
      spacing="16.0" styleClass="page-view" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="page-header">
        <Label styleClass="page-header-title" text="Teklifler"/>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox spacing="10.0" styleClass="page-header-actions">
            <Button fx:id="refreshBtn" onAction="#handleRefresh" styleClass="btn-secondary" text="Yenile"/>
            <Button fx:id="newProposalBtn" onAction="#handleNewProposal" styleClass="btn-primary" text="+ Yeni Teklif"/>
        </HBox>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="Durum:"/>
        <ComboBox fx:id="statusFilter" onAction="#handleFilterChange" prefWidth="150"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField" prefWidth="250" promptText="Ara..."/>
    </HBox>

    <Separator/>

    <TableView fx:id="proposalsTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="60" text="No"/>
            <TableColumn fx:id="colCustomer" prefWidth="180" text="Müşteri"/>
            <TableColumn fx:id="colPreparedBy" prefWidth="150" text="Hazırlayan"/>
            <TableColumn fx:id="colTotal" prefWidth="120" text="Tutar"/>
            <TableColumn fx:id="colStatus" prefWidth="100" text="Durum"/>
            <TableColumn fx:id="colValidUntil" prefWidth="120" text="Geçerlilik"/>
            <TableColumn fx:id="colActions" prefWidth="200" text="İşlemler"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
