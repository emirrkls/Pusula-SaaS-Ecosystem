<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.ExpenseDialogController"
      spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <Label styleClass="dialog-title" text="Yeni Gider Ekle" />
   <Label styleClass="field-label" text="Kategori:" />
   <ComboBox fx:id="comboCategory" maxWidth="1.7976931348623157E308" />
   <Label styleClass="field-label" text="Tutar (₺):" />
   <CurrencyTextField fx:id="txtAmount" promptText="0,00" />
   <Label styleClass="field-label" text="Tarih:" />
   <DatePicker fx:id="datePicker" maxWidth="1.7976931348623157E308" />
   <Label styleClass="field-label" text="Açıklama:" />
   <TextArea fx:id="txtDescription" prefRowCount="3" promptText="Açıklama girin..." />
   <HBox spacing="10.0">
      <Region HBox.hgrow="ALWAYS" />
      <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-secondary" text="İptal" />
      <Button mnemonicParsing="false" onAction="#handleSave" styleClass="btn-success" text="Kaydet" />
   </HBox>
</VBox>
