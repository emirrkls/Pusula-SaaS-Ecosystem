<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.TransferStockDialogController"
      prefHeight="680.0" prefWidth="550.0" spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <Label styleClass="dialog-title" text="Stok Transfer" />
   <Separator />

   <VBox spacing="6.0">
      <Label styleClass="field-label" text="Transfer Yönü:" />
      <HBox spacing="15.0">
         <RadioButton fx:id="radioToVehicle" selected="true" text="Depo → Araca">
            <toggleGroup>
               <ToggleGroup fx:id="transferDirection" />
            </toggleGroup>
         </RadioButton>
         <RadioButton fx:id="radioToWarehouse" text="Araçtan → Depoya" toggleGroup="$transferDirection" />
      </HBox>
   </VBox>

   <VBox spacing="6.0">
      <Label styleClass="field-label" text="Araç Seçin:" />
      <ComboBox fx:id="vehicleComboBox" prefWidth="500.0" promptText="Araç seçiniz..." />
   </VBox>

   <VBox spacing="8.0" styleClass="info-panel-light">
      <Label fx:id="vehicleStockPreviewLabel" styleClass="field-label" text="Araç Mevcut Stoku:" />
      <ListView fx:id="vehicleStockListView" minHeight="180.0" prefHeight="180.0" prefWidth="500.0" styleClass="compact-list" />
   </VBox>

   <Separator />

   <VBox spacing="6.0">
      <Label styleClass="field-label" text="Parça Seçin (arama yapabilirsiniz):" />
      <ComboBox fx:id="inventoryComboBox" prefWidth="500.0" promptText="Parça adı yazın veya seçin..." />
   </VBox>

   <HBox alignment="CENTER_LEFT" spacing="30.0" styleClass="stats-bar">
      <VBox spacing="3.0">
         <Label styleClass="muted-label" text="Mevcut Depo Stoku:" />
         <Label fx:id="warehouseStockLabel" styleClass="stat-value-blue" text="0" />
      </VBox>
      <VBox spacing="3.0">
         <Label styleClass="muted-label" text="Mevcut Araç Stoku:" />
         <Label fx:id="vehicleStockLabel" styleClass="stat-value-green" text="0" />
      </VBox>
   </HBox>

   <HBox alignment="CENTER_LEFT" spacing="15.0">
      <Label styleClass="field-label" text="Transfer Miktarı:" />
      <Spinner fx:id="quantitySpinner" editable="true" prefWidth="120.0" />
   </HBox>

   <Separator />

   <HBox alignment="CENTER_RIGHT" spacing="10.0">
      <Button onAction="#handleCancel" prefWidth="100.0" styleClass="btn-secondary" text="İptal" />
      <Button fx:id="transferButton" onAction="#handleTransfer" prefWidth="120.0" styleClass="btn-success" text="Transfer Et" />
   </HBox>
</VBox>
