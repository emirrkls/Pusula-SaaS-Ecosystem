<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.pusula.desktop.controller.FinanceController">
   <top>
      <Label text="%finance.title" BorderPane.alignment="CENTER_LEFT">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
         <BorderPane.margin>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </BorderPane.margin>
      </Label>
   </top>
   <center>
      <VBox spacing="15.0">
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="0.0" />
         </padding>
         <children>
      <TabPane BorderPane.alignment="CENTER" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
         <tabs>
            <!-- TAB 1: OPERASYON (DAILY OPERATIONS) -->
            <Tab text="%finance.tab.operations">
               <VBox spacing="12.0" styleClass="finance-panel">
                  <padding>
                     <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                  </padding>
                  <children>
                     <!-- Header with Date -->
                     <HBox alignment="CENTER_LEFT" spacing="10.0">
                        <children>
                           <Label text="%finance.daily_operations" styleClass="section-title">
                              <font>
                                 <Font name="System Bold" size="18.0" />
                              </font>
                           </Label>
                           <Region HBox.hgrow="ALWAYS" />
                           <Label fx:id="currentDateLabel" styleClass="date-label">
                              <font>
                                 <Font size="14.0" />
                              </font>
                           </Label>
                        </children>
                     </HBox>

                     <Separator />

                     <!-- Overdue Alert (compact red bar) -->
                     <HBox fx:id="overduePaymentBox" alignment="CENTER_LEFT" spacing="8.0"
                           style="-fx-background-color: #fee2e2; -fx-border-color: #ef4444; -fx-border-width: 0 0 0 4; -fx-padding: 8 12; -fx-background-radius: 4; -fx-border-radius: 4;"
                           visible="false" managed="false">
                        <children>
                           <Label text="🚨" style="-fx-font-size: 14px;"/>
                           <Label fx:id="overdueMessageLabel"
                                  style="-fx-font-weight: bold; -fx-text-fill: #991b1b; -fx-font-size: 12px;"
                                  wrapText="true" HBox.hgrow="ALWAYS"/>
                           <Button text="Öde" onAction="#handleAddExpenseUnified"
                                   style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 4 12; -fx-background-radius: 4; -fx-cursor: hand;"/>
                        </children>
                     </HBox>

                     <!-- Upcoming Alert (compact yellow bar) -->
                     <HBox fx:id="paymentAlertBox" alignment="CENTER_LEFT" spacing="8.0"
                           style="-fx-background-color: #fef3c7; -fx-border-color: #f59e0b; -fx-border-width: 0 0 0 4; -fx-padding: 8 12; -fx-background-radius: 4; -fx-border-radius: 4;"
                           visible="false" managed="false">
                        <children>
                           <Label text="⚠️" style="-fx-font-size: 14px;"/>
                           <Label fx:id="alertMessageLabel"
                                  style="-fx-font-weight: bold; -fx-text-fill: #92400e; -fx-font-size: 12px;"
                                  wrapText="true" HBox.hgrow="ALWAYS"/>
                           <Button text="Öde" onAction="#handleAddExpenseUnified"
                                   style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 4 12; -fx-background-radius: 4; -fx-cursor: hand;"/>
                        </children>
                     </HBox>

                     <!-- Split Table: Expenses & Incomes -->
                     <SplitPane dividerPositions="0.5" VBox.vgrow="ALWAYS">
                        <items>
                           <!-- LEFT: Today's Expenses -->
                           <VBox spacing="8.0">
                              <children>
                                 <HBox alignment="CENTER_LEFT" spacing="10.0" minHeight="35">
                                    <children>
                                       <Label text="%finance.todays_expense">
                                          <font>
                                             <Font name="System Bold" size="14.0" />
                                          </font>
                                       </Label>
                                       <Region HBox.hgrow="ALWAYS" />
                                       <Button mnemonicParsing="false" onAction="#handleAddExpenseUnified"
                                               style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-padding: 6 16; -fx-background-radius: 6; -fx-cursor: hand;"
                                               text="%unified_expense.btn.add_expense" />
                                    </children>
                                 </HBox>
                                 <TableView fx:id="todayExpensesTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                       <TableColumn fx:id="colTodayCategory" prefWidth="90.0" text="%table.category" />
                                       <TableColumn fx:id="colTodayDescription" prefWidth="120.0" text="%table.description" />
                                       <TableColumn fx:id="colTodayAmount" prefWidth="80.0" text="%table.amount" />
                                       <TableColumn fx:id="colTodayActions" text="%table.actions" prefWidth="120.0" />
                                    </columns>
                                    <columnResizePolicy>
                                       <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                 </TableView>
                                 <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                       <Label text="%finance.total_expense" styleClass="total-label" />
                                       <Label fx:id="todayExpenseLabel" text="0 ₺" styleClass="total-value" 
                                              style="-fx-text-fill: #e74c3c;">
                                          <font>
                                             <Font name="System Bold" size="14.0" />
                                          </font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                           
                           <!-- RIGHT: Today's Incomes -->
                           <VBox spacing="8.0">
                              <children>
                                 <!-- Header with matching height to left panel -->
                                 <HBox alignment="CENTER_LEFT" spacing="10.0" minHeight="35">
                                    <children>
                                       <Label text="%finance.todays_income">
                                          <font>
                                             <Font name="System Bold" size="14.0" />
                                          </font>
                                       </Label>
                                       <Region HBox.hgrow="ALWAYS" />
                                       <!-- Empty space to match left panel button bar height -->
                                       <Region prefHeight="29.0" />
                                    </children>
                                 </HBox>
                                 <TableView fx:id="todayIncomesTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                       <TableColumn fx:id="colIncomeCustomer" prefWidth="120.0" text="%table.customer" />
                                       <TableColumn fx:id="colIncomeTicket" prefWidth="80.0" text="%finance.ticket_id" />
                                       <TableColumn fx:id="colIncomeAmount" prefWidth="100.0" text="%table.amount" />
                                    </columns>
                                    <columnResizePolicy>
                                       <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                 </TableView>
                                 <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                    <children>
                                       <Label text="%finance.total_income" styleClass="total-label" />
                                       <Label fx:id="todayIncomeLabel" text="0 ₺" styleClass="total-value" 
                                              style="-fx-text-fill: #27ae60;">
                                          <font>
                                             <Font name="System Bold" size="14.0" />
                                          </font>
                                       </Label>
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                        </items>
                     </SplitPane>

                     <Separator />

                     <!-- Net Cash and Close Day Button -->
                     <VBox spacing="12.0">
                        <children>
                           <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #ecf0f1; -fx-padding: 12;">
                              <children>
                                 <Label text="%finance.net_cash">
                                    <font>
                                       <Font name="System Bold" size="16.0" />
                                    </font>
                                 </Label>
                                 <Label fx:id="netCashLabel" text="0 ₺" styleClass="net-cash-value">
                                    <font>
                                       <Font name="System Bold" size="18.0" />
                                    </font>
                                 </Label>
                              </children>
                           </HBox>
                           <Button fx:id="closeDayButton" mnemonicParsing="false" maxWidth="Infinity" 
                                   onAction="#handleCloseDay" 
                                   style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-padding: 12;" 
                                   text="%finance.close_day" />
                        </children>
                     </VBox>
                  </children>
               </VBox>
            </Tab>

            <!-- TAB 2: ANALİZ (ANALYTICS & CHARTS) -->
            <Tab text="%finance.tab.analytics">
               <VBox spacing="20.0" styleClass="finance-panel">
                  <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>
                  <children>
                     <Label text="%finance.analytics" styleClass="section-title">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>

                     <Separator />

                     <!-- LineChart for Income/Expense Trends (BIGGER) -->
                     <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                        <children>
                           <Label text="%finance.income_expense_trend">
                              <font>
                                 <Font name="System Bold" size="14.0" />
                              </font>
                           </Label>
                           <LineChart fx:id="trendChart" VBox.vgrow="ALWAYS" legendVisible="true" 
                                      prefHeight="350.0">
                              <xAxis>
                                 <javafx.scene.chart.CategoryAxis label="%chart.date" />
                              </xAxis>
                              <yAxis>
                                 <NumberAxis label="%chart.amount_tl" />
                              </yAxis>
                           </LineChart>
                        </children>
                     </VBox>

                     <Separator />

                     <!-- PieChart for Category Distribution (BIGGER) -->
                     <VBox spacing="8.0" VBox.vgrow="ALWAYS">
                        <children>
                           <Label text="%finance.expense_distribution">
                              <font>
                                 <Font name="System Bold" size="14.0" />
                              </font>
                           </Label>
                           <PieChart fx:id="expensePieChart" legendVisible="true" VBox.vgrow="ALWAYS" 
                                     prefHeight="350.0" />
                        </children>
                     </VBox>
                  </children>
               </VBox>
            </Tab>

            <!-- TAB 3: RAPORLAR (REPORTS - PLACEHOLDER) -->
            <Tab text="%finance.tab.reports">
               <VBox spacing="15.0" styleClass="finance-panel" alignment="CENTER">
                  <padding>
                     <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                  </padding>
                  <children>
                     <Label text="%finance.reports" styleClass="section-title">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>

                     <Separator />

                                           <!-- Monthly Reports Table -->
                        <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS">
                         <columns>
                            <TableColumn fx:id="colReportPeriod" text="%reports.period" prefWidth="150.0" />
                            <TableColumn fx:id="colReportCarryOver" text="Devir" prefWidth="120.0" />
                            <TableColumn fx:id="colReportIncome" text="%reports.total_income" prefWidth="120.0" />
                            <TableColumn fx:id="colReportExpense" text="%reports.total_expense" prefWidth="120.0" />
                            <TableColumn fx:id="colReportProfit" text="%reports.net_profit" prefWidth="120.0" />
                            <TableColumn fx:id="colReportActions" text="%table.actions" prefWidth="100.0" />
                         </columns>
                         <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                         </columnResizePolicy>
                        </TableView>
                  </children>
               </VBox>
            </Tab>
            
            <!-- TAB 4: CARİ HESAPLAR (CURRENT ACCOUNTS) -->
            <Tab text="%finance.tab.current_accounts">
               <VBox spacing="15.0" styleClass="finance-panel">
                  <padding>
                     <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                  </padding>
                  <children>
                     <Label text="%finance.tab.current_accounts" styleClass="section-title">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>
                     
                     <Separator />
                     
                     <TableView fx:id="currentAccountsTable" VBox.vgrow="ALWAYS">
                        <columns>
                           <TableColumn fx:id="colAccountCustomer" text="%current_account.customer" prefWidth="200.0" />
                           <TableColumn fx:id="colAccountBalance" text="%current_account.balance" prefWidth="150.0" />
                           <TableColumn fx:id="colAccountLastUpdated" text="%current_account.last_updated" prefWidth="180.0" />
                           <TableColumn fx:id="colAccountActions" text="%table.actions" prefWidth="120.0" />
                        </columns>
                        <columnResizePolicy>
                           <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                     </TableView>
                  </children>
               </VBox>
            </Tab>
            
            <!-- TAB 5: BORÇLARIMIZ (OUR DEBTS) -->
            <Tab text="Borçlarımız">
               <fx:include source="company_debts.fxml"/>
            </Tab>
            
            <!-- TAB 6: İŞLETME MÜLKİYETİ (BUSINESS ASSETS) -->
            <Tab text="%finance.tab.assets">
               <VBox alignment="CENTER" spacing="50.0" styleClass="finance-panel">
                  <padding>
                     <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                  </padding>
                  <children>
                     <Label text="%finance.tab.assets" styleClass="section-title">
                        <font>
                           <Font name="System Bold" size="20.0" />
                        </font>
                     </Label>
                     
                     <HBox alignment="CENTER" spacing="80.0">
                        <children>
                           <!-- Left Card: Total Inventory Value -->
                           <VBox alignment="CENTER" spacing="20.0" styleClass="square-card" 
                                 style="-fx-background-color: #3498db; -fx-background-radius: 12; -fx-min-width: 300; -fx-min-height: 300; -fx-pref-width: 300; -fx-pref-height: 300; -fx-max-width: 300; -fx-max-height: 300;">
                              <padding>
                                 <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                              </padding>
                              <children>
                                 <Label text="%finance.card.inventory_value" 
                                        style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" 
                                        wrapText="true" textAlignment="CENTER" />
                                 <Label fx:id="assetInventoryValueLabel" text="₺0.00" 
                                        style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 32px;" />
                              </children>
                           </VBox>
                           
                           <!-- Right Card: Net Cash -->
                           <VBox alignment="CENTER" spacing="20.0" styleClass="square-card" 
                                 style="-fx-background-color: #27ae60; -fx-background-radius: 12; -fx-min-width: 300; -fx-min-height: 300; -fx-pref-width: 300; -fx-pref-height: 300; -fx-max-width: 300; -fx-max-height: 300;">
                              <padding>
                                 <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
                              </padding>
                              <children>
                                 <Label text="%finance.card.net_cash" 
                                        style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;" 
                                        wrapText="true" textAlignment="CENTER" />
                                 <Label fx:id="assetNetCashLabel" text="₺0.00" 
                                        style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 32px;" />
                              </children>
                           </VBox>
                        </children>
                     </HBox>
                  </children>
               </VBox>
            </Tab>
         </tabs>
      </TabPane>
         </children>
      </VBox>
   </center>
</BorderPane>
