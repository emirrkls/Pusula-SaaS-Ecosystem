<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.VehicleDialogController"
      spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <Label fx:id="titleLabel" styleClass="dialog-title" text="%vehicle.add" />
   <VBox spacing="5.0">
      <Label styleClass="field-label" text="%vehicle.license_plate" />
      <TextField fx:id="plateField" promptText="34 ABC 123" />
   </VBox>
   <VBox spacing="5.0">
      <Label styleClass="field-label" text="%vehicle.driver_name" />
      <TextField fx:id="driverField" promptText="e.g. Ahmet Yılmaz" />
   </VBox>
   <CheckBox fx:id="activeCheckBox" selected="true" text="%vehicle.active" />
   <HBox alignment="CENTER_RIGHT" spacing="10.0">
      <VBox.margin>
         <Insets top="10.0" />
      </VBox.margin>
      <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-secondary" text="%button.cancel" />
      <Button defaultButton="true" mnemonicParsing="false" onAction="#handleSave" styleClass="btn-success" text="%button.save" />
   </HBox>
</VBox>
