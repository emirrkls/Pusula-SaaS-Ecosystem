<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="16.0" styleClass="dialog-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pusula.desktop.controller.TicketDetailsController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Label styleClass="dialog-title" text="%ticket.details.title" />
            <Label fx:id="lblStatus" styleClass="page-subtitle" text="STATUS" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnChangeStatus" mnemonicParsing="false" onAction="#handleChangeStatus" styleClass="btn-primary" text="%ticket.change.status" visible="false" managed="false"/>
         </children>
      </HBox>
      
      <!-- Parent Ticket Link -->
      <Label fx:id="lblParentLink" managed="false" styleClass="link-label" text="" underline="true" visible="false" />
      
      <!-- Customer Information Card -->
      <VBox spacing="8.0" styleClass="ticket-details-panel">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <Label styleClass="section-title" text="%ticket.customer_info" />
            <HBox spacing="40.0">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="field-label" text="%customer.name" />
                        <Label fx:id="lblCustomerName" styleClass="field-value" text="-" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0">
                     <children>
                        <Label styleClass="field-label" text="%ticket.customer_phone" />
                        <HBox alignment="CENTER_LEFT" spacing="5.0">
                           <children>
                              <Label fx:id="lblCustomerPhone" styleClass="field-value" text="-" />
                              <Button fx:id="btnWhatsApp" mnemonicParsing="false" onAction="#handleWhatsAppClick" styleClass="btn-whatsapp" text="💬" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="field-label" text="%ticket.customer_address" />
                        <Label fx:id="lblCustomerAddress" styleClass="field-value" text="-" wrapText="true" />
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
      
      <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
         <tabs>
            <Tab text="%ticket.tab.details">
               <content>
                  <ScrollPane fitToWidth="true" styleClass="scroll-pane-transparent">
                     <content>
                        <VBox spacing="15.0">
                           <padding>
                              <Insets bottom="10.0" left="10.0" right="10.0" top="15.0" />
                           </padding>
                           <children>
                              <HBox spacing="20.0">
                                 <children>
                                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label styleClass="muted-label" text="%ticket.description" />
                                          <TextArea fx:id="txtDescription" editable="false" prefHeight="70.0" wrapText="true" />
                                          <Label styleClass="muted-label" text="%ticket.notes" />
                                          <TextArea fx:id="txtNotes" prefHeight="70.0" wrapText="true" />
                                          <Button mnemonicParsing="false" onAction="#handleSaveNotes" styleClass="btn-secondary" text="%ticket.save.notes" />
                                       </children>
                                    </VBox>
                                    
                                    <VBox prefWidth="280.0" spacing="10.0">
                                       <children>
                                          <Label styleClass="muted-label" text="%ticket.assign.technician" />
                                          <HBox spacing="10.0">
                                             <children>
                                                <ComboBox fx:id="comboTechnician" prefWidth="180.0" promptText="%ticket.select.technician" />
                                                <Button minWidth="70.0" mnemonicParsing="false" onAction="#handleAssign" prefWidth="80.0" styleClass="btn-primary" text="%btn.assign" />
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              
                              <VBox spacing="10.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                       <children>
                                          <Label text="%ticket.used.parts">
                                             <font>
                                                <Font name="System Bold" size="16.0" />
                                             </font>
                                          </Label>
                                          <Button fx:id="btnAddPart" mnemonicParsing="false" onAction="#handleAddPart" styleClass="btn-success" text="%ticket.add.part" />
                                       </children>
                                    </HBox>
                                    <TableView fx:id="partsTable" minHeight="100.0" prefHeight="120.0" styleClass="premium-table bordered-table">
                                       <columns>
                                          <TableColumn fx:id="colPartName" prefWidth="250.0" text="%ticket.part.name" />
                                          <TableColumn fx:id="colQuantity" prefWidth="80.0" text="%ticket.quantity" />
                                          <TableColumn fx:id="colPrice" prefWidth="100.0" text="%ticket.price" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                              
                              <!-- External Expenses Section -->
                              <VBox spacing="10.0">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="10.0">
                                       <children>
                                          <Label text="Dış Giderler">
                                             <font>
                                                <Font name="System Bold" size="16.0" />
                                             </font>
                                          </Label>
                                          <Button fx:id="btnAddExpense" mnemonicParsing="false" onAction="#handleAddExpense" styleClass="btn-warning" text="+ Dış Gider Ekle" />
                                       </children>
                                    </HBox>
                                    <TableView fx:id="expensesTable" minHeight="100.0" prefHeight="120.0" styleClass="premium-table bordered-table">
                                       <columns>
                                          <TableColumn fx:id="colExpenseDescription" prefWidth="200.0" text="Açıklama" />
                                          <TableColumn fx:id="colExpenseSupplier" prefWidth="150.0" text="Tedarikçi" />
                                          <TableColumn fx:id="colExpenseAmount" prefWidth="100.0" text="Tutar" />
                                          <TableColumn fx:id="colExpenseActions" prefWidth="80.0" text="" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>
            <Tab text="%ticket.tab.history">
               <content>
                  <ScrollPane fitToWidth="true" styleClass="scroll-pane-transparent">
                     <content>
                        <VBox fx:id="timelineContainer" spacing="15.0" styleClass="timeline-container">
                           <padding>
                              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                           </padding>
                        </VBox>
                     </content>
                  </ScrollPane>
               </content>
            </Tab>
         </tabs>
      </TabPane>
      
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <children>
            <Button fx:id="btnPrintPdf" onAction="#handlePrintPdf" prefWidth="120.0" styleClass="btn-purple" text="%btn.print" />
            <Button fx:id="btnCreateRecall" managed="false" onAction="#handleCreateRecall" prefWidth="180.0" styleClass="btn-warning" text="%ticket.recall" visible="false" />
            <Button fx:id="btnEditCompleted" managed="false" onAction="#handleEditCompleted" prefWidth="220.0" styleClass="btn-purple" text="%btn.edit_completed" visible="false" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="btnCancelService" mnemonicParsing="false" onAction="#handleCancelService" prefWidth="150.0" styleClass="btn-danger" text="%ticket.cancel" />
            <Button fx:id="btnCompleteService" mnemonicParsing="false" onAction="#handleCompleteService" prefWidth="150.0" styleClass="btn-success" text="%ticket.complete" />
         </children>
      </HBox>
   </children>
</VBox>
