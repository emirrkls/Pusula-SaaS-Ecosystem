<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.PayFixedExpenseDialogController"
      prefHeight="550" prefWidth="900" spacing="15" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <Label styleClass="dialog-title" text="%finance.pay_fixed_expense_dialog.select"/>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label styleClass="field-label" text="%finance.pay_fixed_expense_dialog.payment_date"/>
        <DatePicker fx:id="dtPaymentDate" prefWidth="150"/>
    </HBox>

    <TableView fx:id="expensesTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colSelect" prefWidth="50.0" text=""/>
            <TableColumn fx:id="colName" prefWidth="160.0" text="%finance.pay_fixed_expense_dialog.name"/>
            <TableColumn fx:id="colCategory" prefWidth="100.0" text="%fixed_expense.category"/>
            <TableColumn fx:id="colFrequency" prefWidth="80.0" text="Sıklık"/>
            <TableColumn fx:id="colAmount" prefWidth="90.0" text="Varsayılan"/>
            <TableColumn fx:id="colPayAmount" prefWidth="100.0" text="Ödeme Tutarı"/>
            <TableColumn fx:id="colLinkedInfo" prefWidth="180.0" text="Bağlı Ödeme"/>
            <TableColumn fx:id="colDayOfMonth" prefWidth="60.0" text="%fixed_expense.day_of_month"/>
            <TableColumn fx:id="colDaysUntil" prefWidth="80.0" text="%finance.pay_fixed_expense_dialog.days_until"/>
            <TableColumn fx:id="colStatus" prefWidth="80.0" text="%finance.pay_fixed_expense_dialog.status"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="%finance.pay_fixed_expense_dialog.cancel"/>
        <Button onAction="#handlePay" styleClass="btn-success" text="%finance.pay_fixed_expense_dialog.pay_selected"/>
    </HBox>
</VBox>
