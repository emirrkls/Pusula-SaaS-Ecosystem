<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.FixedExpenseDialogController"
      prefWidth="400.0" spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <Label styleClass="dialog-title" text="Sabit Gider Tanımı"/>
    <Separator />

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="100.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0" prefWidth="200.0" />
        </columnConstraints>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label" text="%settings.name" />
        <TextField fx:id="nameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label" text="%settings.default_amount" />
        <CurrencyTextField fx:id="amountField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label" text="%table.category" />
        <ComboBox fx:id="categoryComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="field-label" text="%expense.frequency" />
        <ComboBox fx:id="frequencyCombo" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity" />
        <Label fx:id="dayLabel" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label" text="%settings.day_of_month" />
        <Spinner fx:id="daySpinner" GridPane.columnIndex="1" GridPane.rowIndex="4" editable="true" maxWidth="Infinity" />
        <ComboBox fx:id="dayOfWeekCombo" GridPane.columnIndex="1" GridPane.rowIndex="4" managed="false" maxWidth="Infinity" visible="false" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="field-label" text="%table.description" />
        <TextField fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="field-label" text="Bağlı Gider" />
        <ComboBox fx:id="linkedExpenseCombo" GridPane.columnIndex="1" GridPane.rowIndex="6"
                  maxWidth="Infinity" promptText="(Opsiyonel) Haftalık gider seçin..." />
    </GridPane>

    <Separator />

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="İptal" />
        <Button onAction="#handleSave" styleClass="btn-success" text="Kaydet" />
    </HBox>
</VBox>
