<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.PartSelectionDialogController"
      prefHeight="500.0" prefWidth="600.0" spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <Label styleClass="dialog-title" text="%part.selection.title" />
   <TextField fx:id="searchField" promptText="%part.selection.search" />
   <TableView fx:id="partsTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="colPartName" prefWidth="200.0" text="%table.partname" />
         <TableColumn fx:id="colStock" prefWidth="100.0" text="%table.quantity" />
         <TableColumn fx:id="colPrice" prefWidth="120.0" text="%table.sellprice" />
      </columns>
      <columnResizePolicy>
         <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
      </columnResizePolicy>
   </TableView>
   <HBox alignment="CENTER_LEFT" spacing="10.0">
      <Label styleClass="field-label" text="%part.selection.quantity" />
      <Spinner fx:id="quantitySpinner" editable="true" prefWidth="100.0" />
   </HBox>
   <HBox alignment="CENTER_RIGHT" spacing="10.0">
      <Button mnemonicParsing="false" onAction="#handleCancel" prefWidth="100.0" styleClass="btn-secondary" text="%btn.cancel" />
      <Button mnemonicParsing="false" onAction="#handleSelect" prefWidth="100.0" styleClass="btn-success" text="%part.selection.select" />
   </HBox>
</VBox>
