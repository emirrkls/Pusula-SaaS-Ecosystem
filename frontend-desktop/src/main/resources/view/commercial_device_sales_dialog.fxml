<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.CommercialDeviceSalesDialogController"
      prefWidth="450" spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <Label styleClass="dialog-title" text="%commercial.sale.title"/>
    <Separator/>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefWidth="120" styleClass="field-label" text="%commercial.sale.device"/>
        <Label fx:id="deviceInfoLabel" styleClass="muted-label" text="Device Info Here"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefWidth="120" styleClass="field-label" text="%commercial.sale.customer"/>
        <ComboBox fx:id="customerComboBox" prefWidth="230" promptText="%commercial.sale.select_customer"/>
        <Button fx:id="addCustomerBtn" onAction="#handleAddCustomer" styleClass="btn-secondary" text="+"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefWidth="120" styleClass="field-label" text="%commercial.sale.price"/>
        <CurrencyTextField fx:id="sellingPriceField" prefWidth="200" promptText="0,00"/>
        <Label text="₺"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefWidth="120" styleClass="field-label" text="%commercial.sale.payment_method"/>
        <ComboBox fx:id="paymentMethodComboBox" prefWidth="200" promptText="%commercial.sale.select_payment"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefWidth="120" styleClass="field-label" text="%commercial.sale.date"/>
        <DatePicker fx:id="saleDatePicker" prefWidth="200"/>
    </HBox>

    <Separator/>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="%button.cancel"/>
        <Button onAction="#handleSale" styleClass="btn-success" text="%commercial.sale.complete"/>
    </HBox>
</VBox>
