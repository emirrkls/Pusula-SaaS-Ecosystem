<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.ActivityLogController"
      spacing="16" styleClass="page-view" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="8" left="0" right="0" top="8"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="page-header">
        <Label styleClass="page-header-title" text="%activity_log.title" HBox.hgrow="ALWAYS"/>
        <Label fx:id="totalCountLabel" styleClass="page-subtitle" text="Toplam: 0"/>
        <Button onAction="#loadAuditLogs" styleClass="btn-secondary" text="%common.refresh"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
        <Label text="%activity_log.filter.from"/>
        <DatePicker fx:id="startDatePicker" prefWidth="150" promptText="%activity_log.filter.from"/>
        <Label text="%activity_log.filter.to"/>
        <DatePicker fx:id="endDatePicker" prefWidth="150" promptText="%activity_log.filter.to"/>
        <Label text="Kullanıcı"/>
        <ComboBox fx:id="userCombo" prefWidth="150" promptText="Tümü"/>
        <Label text="%activity_log.action"/>
        <ComboBox fx:id="actionTypeCombo" prefWidth="120" promptText="%activity_log.filter.all"/>
        <Button onAction="#applyFilters" styleClass="btn-primary" text="%activity_log.filter.apply"/>
        <Button onAction="#resetFilters" styleClass="btn-secondary" text="%activity_log.filter.reset"/>
    </HBox>

    <TableView fx:id="auditLogTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="timestampColumn" minWidth="140" prefWidth="140" text="%activity_log.timestamp"/>
            <TableColumn fx:id="userColumn" minWidth="100" prefWidth="130" text="%activity_log.user"/>
            <TableColumn fx:id="actionColumn" minWidth="100" prefWidth="120" text="%activity_log.action"/>
            <TableColumn fx:id="entityColumn" minWidth="90" prefWidth="110" text="%activity_log.entity"/>
            <TableColumn fx:id="descriptionColumn" minWidth="200" prefWidth="280" text="%activity_log.description"/>
            <TableColumn fx:id="actionsColumn" minWidth="80" prefWidth="80" text="İşlemler"/>
        </columns>
        <placeholder>
            <Label text="%activity_log.no_data"/>
        </placeholder>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER" spacing="10" styleClass="pagination-bar">
        <Button fx:id="btnPrevious" onAction="#previousPage" styleClass="btn-secondary" text="◀"/>
        <Label fx:id="pageLabel" styleClass="page-subtitle" text="Sayfa 1 / 1"/>
        <Button fx:id="btnNext" onAction="#nextPage" styleClass="btn-secondary" text="▶"/>
    </HBox>
</VBox>
