<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.CompanyDebtDialogController"
      prefWidth="400" spacing="15" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <Label styleClass="dialog-title" text="Borç Ekle"/>
    <Separator/>

    <GridPane hgap="10" vgap="10">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="100" prefWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200" prefWidth="250"/>
        </columnConstraints>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label" text="Alacaklı *"/>
        <TextField fx:id="creditorField" GridPane.columnIndex="1" GridPane.rowIndex="0" promptText="Tedarikçi adı"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label" text="Tutar (₺) *"/>
        <CurrencyTextField fx:id="amountField" GridPane.columnIndex="1" GridPane.rowIndex="1" promptText="0,00"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label" text="Açıklama"/>
        <TextField fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="2" promptText="Ne için borçlanıldı?"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="field-label" text="Borç Tarihi"/>
        <DatePicker fx:id="debtDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label" text="Vade Tarihi"/>
        <DatePicker fx:id="dueDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="4" maxWidth="Infinity"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="field-label" text="Telefon"/>
        <TextField fx:id="phoneField" GridPane.columnIndex="1" GridPane.rowIndex="5" promptText="İletişim numarası"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="field-label" text="Notlar"/>
        <TextArea fx:id="notesArea" GridPane.columnIndex="1" GridPane.rowIndex="6" prefRowCount="2"/>
    </GridPane>

    <Separator/>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="İptal"/>
        <Button onAction="#handleSave" styleClass="btn-success" text="Kaydet"/>
    </HBox>
</VBox>
