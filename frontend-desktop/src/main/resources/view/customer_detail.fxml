<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.CustomerDetailController"
      prefHeight="600.0" prefWidth="800.0" spacing="20.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="dialog-title" text="%customer.details.title" />
      <HBox spacing="20.0">
         <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <Label styleClass="field-label" text="%customer.name" />
            <TextField fx:id="nameField" />
         </VBox>
         <VBox spacing="10.0" HBox.hgrow="ALWAYS">
            <Label styleClass="field-label" text="%customer.phone" />
            <HBox alignment="CENTER_LEFT" spacing="5">
               <TextField fx:id="phoneField" HBox.hgrow="ALWAYS" />
               <Button fx:id="btnWhatsApp" mnemonicParsing="false" onAction="#handleWhatsAppClick"
                       styleClass="btn-whatsapp, btn-whatsapp-icon"/>
            </HBox>
         </VBox>
      </HBox>
      <VBox spacing="10.0">
         <Label styleClass="field-label" text="%customer.address" />
         <TextField fx:id="addressField" />
      </VBox>
      <HBox alignment="CENTER_RIGHT" spacing="10.0">
         <Button mnemonicParsing="false" onAction="#handleSave" styleClass="btn-success" text="%btn.save" />
         <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-secondary" text="%btn.cancel" />
      </HBox>
      <Label styleClass="section-title" text="%customer.history.title">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </Label>
      <TableView fx:id="historyTable" prefHeight="200.0" styleClass="premium-table" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colDate" prefWidth="100.0" text="%table.date" />
          <TableColumn fx:id="colIssue" prefWidth="200.0" text="%table.issue" />
          <TableColumn fx:id="colStatus" prefWidth="100.0" text="%table.status" />
          <TableColumn fx:id="colTechnician" prefWidth="150.0" text="%table.technician" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </children>
</VBox>
