<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pusula.desktop.controller.CompanyDebtController"
      spacing="15" styleClass="subsection-panel">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="page-header">
        <Label styleClass="page-header-title" text="Borçlarımız" HBox.hgrow="ALWAYS"/>
        <Label fx:id="totalDebtLabel" styleClass="debt-total-label" text="Toplam Borç: 0 ₺"/>
        <Button onAction="#handleAddDebt" styleClass="btn-primary" text="+ Borç Ekle"/>
        <Button onAction="#loadDebts" styleClass="btn-secondary" text="Yenile"/>
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="filter-bar">
        <Label text="Filtre:"/>
        <ComboBox fx:id="statusFilter" prefWidth="150" promptText="Tümü"/>
        <Button onAction="#applyFilter" styleClass="btn-primary" text="Uygula"/>
    </HBox>

    <TableView fx:id="debtTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCreditor" minWidth="150" prefWidth="180" text="Alacaklı"/>
            <TableColumn fx:id="colDescription" minWidth="150" prefWidth="200" text="Açıklama"/>
            <TableColumn fx:id="colOriginal" minWidth="100" prefWidth="120" text="Toplam Borç"/>
            <TableColumn fx:id="colRemaining" minWidth="100" prefWidth="120" text="Kalan Borç"/>
            <TableColumn fx:id="colDebtDate" minWidth="90" prefWidth="100" text="Borç Tarihi"/>
            <TableColumn fx:id="colDueDate" minWidth="90" prefWidth="100" text="Vade Tarihi"/>
            <TableColumn fx:id="colStatus" minWidth="80" prefWidth="100" text="Durum"/>
            <TableColumn fx:id="colActions" minWidth="180" prefWidth="200" text="İşlemler"/>
        </columns>
        <placeholder>
            <Label text="Henüz borç kaydı bulunmuyor"/>
        </placeholder>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
