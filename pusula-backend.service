[Unit]
Description=Pusula Backend Service
After=network.target postgresql.service

[Service]
User=root
WorkingDirectory=/root/pusula
ExecStart=/usr/bin/java -jar /root/pusula/backend-0.0.1-SNAPSHOT.jar
SuccessExitStatus=143
Restart=always
RestartSec=10
Environment="DB_PASSWORD=YOUR_DB_PASSWORD_HERE"

[Install]
WantedBy=multi-user.target
