<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="16.0" styleClass="page-view" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pusula.desktop.controller.ServiceTicketController">
   <padding>
      <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="page-header">
         <children>
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
               <children>
                  <Label styleClass="page-header-title" text="%tickets.title" />
                  <Label fx:id="resultCountLabel" styleClass="page-subtitle" text="" />
               </children>
            </VBox>
            <HBox spacing="10.0" styleClass="page-header-actions">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleCreateTicket" styleClass="btn-primary" text="%btn.add" />
                  <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" text="%btn.refresh" />
               </children>
            </HBox>
         </children>
      </HBox>

      <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" styleClass="filter-scroll" vbarPolicy="NEVER">
         <content>
            <HBox fx:id="filterChipContainer" spacing="8.0" styleClass="filter-chip-container" />
         </content>
      </ScrollPane>

      <TextField fx:id="txtSearch" promptText="%search.placeholder" />

      <StackPane VBox.vgrow="ALWAYS">
         <children>
            <ListView fx:id="ticketsListView" styleClass="tickets-list" VBox.vgrow="ALWAYS" />
            <VBox fx:id="emptyStateBox" alignment="CENTER" managed="false" spacing="8.0" styleClass="empty-state" visible="false">
               <children>
                  <Label styleClass="empty-state-title" text="Bu filtrede sonuç yok" />
                  <Label styleClass="empty-state-subtitle" text="Farklı bir filtre seçmeyi veya yeni fiş oluşturmayı deneyin." />
               </children>
            </VBox>
            <StackPane fx:id="loadingOverlay" managed="false" styleClass="loading-overlay" visible="false">
               <children>
                  <ProgressIndicator />
               </children>
            </StackPane>
         </children>
      </StackPane>
   </children>
</VBox>
