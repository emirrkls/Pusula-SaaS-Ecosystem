<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.CommercialDeviceDialogController"
      prefWidth="400.0" spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label styleClass="dialog-title" text="%commercial.add"/>

    <GridPane hgap="10.0" vgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="100.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label" text="%commercial.brand" />
        <TextField fx:id="txtBrand" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label" text="%commercial.model" />
        <TextField fx:id="txtModel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label" text="%commercial.device_type" />
        <ComboBox fx:id="cmbDeviceType" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="200.0" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="field-label" text="%commercial.btu" />
        <TextField fx:id="txtBtu" GridPane.columnIndex="1" GridPane.rowIndex="3" promptText="(opsiyonel)" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="field-label" text="%commercial.gas" />
        <ComboBox fx:id="cmbGasType" GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="200.0" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="field-label" text="%commercial.quantity" />
        <TextField fx:id="txtQuantity" GridPane.columnIndex="1" GridPane.rowIndex="5" text="0" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="field-label" text="%commercial.buying_price" />
        <CurrencyTextField fx:id="txtBuyingPrice" GridPane.columnIndex="1" GridPane.rowIndex="6" promptText="₺" />
        <Label GridPane.columnIndex="0" GridPane.rowIndex="7" styleClass="field-label" text="%commercial.selling_price" />
        <CurrencyTextField fx:id="txtSellingPrice" GridPane.columnIndex="1" GridPane.rowIndex="7" promptText="₺" />
    </GridPane>

    <HBox alignment="CENTER_RIGHT" spacing="10.0">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="İptal" />
        <Button onAction="#handleSave" styleClass="btn-success" text="Kaydet" />
    </HBox>
</VBox>
