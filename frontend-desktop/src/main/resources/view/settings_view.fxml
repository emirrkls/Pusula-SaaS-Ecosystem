<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" styleClass="page-view" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.pusula.desktop.controller.SettingsController">
    <padding>
        <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
    </padding>
    <children>
        <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
            <tabs>
                <!-- User Management Tab -->
                <Tab text="%settings.users">
                    <content>
                        <VBox spacing="15.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="%settings.user_management">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="%settings.add_user" onAction="#handleAddUser"
                                                styleClass="btn-success" />
                                        <Button text="%settings.edit_user" onAction="#handleEditUser"
                                                styleClass="btn-primary" />
                                        <Button text="%settings.reset_password" onAction="#handleResetPassword"
                                                styleClass="btn-warning" />
                                        <Button text="%settings.delete_user" onAction="#handleDeleteUser"
                                                styleClass="btn-danger" />
                                    </children>
                                </HBox>
                                
                                <TableView fx:id="usersTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colUsername" prefWidth="150.0" text="%settings.username" />
                                        <TableColumn fx:id="colFullName" prefWidth="200.0" text="%settings.full_name" />
                                        <TableColumn fx:id="colRole" prefWidth="120.0" text="%settings.role" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </content>
                </Tab>
                
                <!-- Company Profile Tab -->
                <Tab text="%settings.company">
                    <content>
                        <VBox spacing="15.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="%settings.company_profile">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                
                                <GridPane hgap="15.0" vgap="12.0" maxWidth="600.0">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="NEVER" minWidth="120.0" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>
                                    
                                    <!-- Company Name -->
                                    <Label text="%settings.company_name" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                    <TextField fx:id="txtCompanyName" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                    
                                    <!-- Phone -->
                                    <Label text="%settings.company_phone" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                    <TextField fx:id="txtCompanyPhone" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                    
                                    <!-- Email -->
                                    <Label text="%settings.company_email" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                    <TextField fx:id="txtCompanyEmail" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                    
                                    <!-- Address -->
                                    <Label text="%settings.company_address" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                    <TextArea fx:id="txtCompanyAddress" prefRowCount="3" 
                                              GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                              
                                    <!-- Logo Upload -->
                                    <Label text="%settings.company_logo" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                    <HBox spacing="10.0" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                       <children>
                                          <VBox styleClass="logo-upload-preview"
                                                minWidth="150" minHeight="60" alignment="CENTER">
                                              <javafx.scene.image.ImageView fx:id="imgCompanyLogo" fitHeight="50.0" fitWidth="140.0" pickOnBounds="true" preserveRatio="true" />
                                          </VBox>
                                          <Button text="%settings.upload_logo" onAction="#handleUploadLogo"
                                                  styleClass="btn-primary" />
                                       </children>
                                    </HBox>
                                </GridPane>
                                
                                <HBox spacing="10.0">
                                    <children>
                                        <Button text="%settings.save_company" onAction="#handleSaveCompany"
                                                styleClass="btn-success" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </Tab>
                
                <!-- Vehicles Tab -->
                <Tab text="%settings.vehicles">
                    <content>
                        <VBox spacing="15.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="%settings.vehicles">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="%vehicle.add" onAction="#handleAddVehicle"
                                                styleClass="btn-success" />
                                        <Button text="%vehicle.edit" onAction="#handleEditVehicle"
                                                styleClass="btn-primary" />
                                        <Button text="%button.delete" onAction="#handleDeleteVehicle"
                                                styleClass="btn-danger" />
                                    </children>
                                </HBox>
                                
                                <TableView fx:id="vehiclesTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colVehicleId" prefWidth="60.0" text="ID" />
                                        <TableColumn fx:id="colLicensePlate" prefWidth="150.0" text="%vehicle.license_plate" />
                                        <TableColumn fx:id="colDriverName" prefWidth="200.0" text="%vehicle.driver_name" />
                                        <TableColumn fx:id="colVehicleStatus" prefWidth="100.0" text="%dashboard.table.status" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </content>
                </Tab>
                
                <!-- Finance Settings Tab -->
                <Tab text="%settings.finance">
                    <content>
                        <VBox spacing="15.0">
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                            <children>
                                <Label text="%settings.fixed_expenses">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Button text="%settings.add_fixed_expense" onAction="#handleAddFixedExpense"
                                                styleClass="btn-success" />
                                        <Button text="%settings.edit_fixed_expense" onAction="#handleEditFixedExpense"
                                                styleClass="btn-primary" />
                                        <Button text="%settings.delete_fixed_expense" onAction="#handleDeleteFixedExpense"
                                                styleClass="btn-danger" />
                                    </children>
                                </HBox>
                                
                                <TableView fx:id="fixedExpensesTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colName" prefWidth="200.0" text="%settings.name" />
                                        <TableColumn fx:id="colAmount" prefWidth="120.0" text="%settings.default_amount" />
                                        <TableColumn fx:id="colCategory" prefWidth="120.0" text="%table.category" />
                                        <TableColumn fx:id="colDayOfMonth" prefWidth="100.0" text="%settings.day_of_month" />
                                        <TableColumn fx:id="colDescription" prefWidth="200.0" text="%table.description" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </children>
</VBox>
