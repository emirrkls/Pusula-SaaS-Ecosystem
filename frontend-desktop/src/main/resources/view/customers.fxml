<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="16.0" styleClass="page-view" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pusula.desktop.controller.CustomerController">
   <padding>
      <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
   </padding>
   <children>
      <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="page-header">
         <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label styleClass="page-header-title" text="%customers.title" />
            <Label fx:id="resultCountLabel" styleClass="page-subtitle" text="" />
         </VBox>
         <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="page-header-actions">
            <TextField fx:id="searchField" prefWidth="200.0" promptText="%common.search" />
            <Button mnemonicParsing="false" onAction="#handleAddCustomer" styleClass="btn-primary" text="%btn.add" />
            <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" text="%btn.refresh" />
         </HBox>
      </HBox>

      <StackPane VBox.vgrow="ALWAYS">
         <ListView fx:id="customersListView" styleClass="tickets-list" VBox.vgrow="ALWAYS" />
         <VBox fx:id="emptyStateBox" alignment="CENTER" managed="false" spacing="8.0" styleClass="empty-state" visible="false">
            <Label styleClass="empty-state-title" text="Müşteri bulunamadı" />
            <Label styleClass="empty-state-subtitle" text="Yeni müşteri ekleyin veya aramayı değiştirin." />
         </VBox>
      </StackPane>
   </children>
</VBox>
