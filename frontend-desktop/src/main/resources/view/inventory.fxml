<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="16.0" styleClass="page-view" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pusula.desktop.controller.InventoryController">
   <padding>
      <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
   </padding>
   <children>
      <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
         <tabs>
            <Tab text="%inventory.tab.stock">
               <content>
                  <VBox spacing="12.0">
                     <padding>
                        <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
                     </padding>
                     <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="page-header">
                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                           <Label styleClass="page-header-title" text="%inventory.tab.stock" />
                           <Label fx:id="resultCountLabel" styleClass="page-subtitle" text="" />
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="page-header-actions">
                           <TextField fx:id="searchField" prefWidth="220.0" promptText="%inventory.search" />
                           <Button mnemonicParsing="false" onAction="#handleExportPdf" styleClass="btn-export" text="%btn.export" />
                           <Button mnemonicParsing="false" onAction="#handleAddItem" styleClass="btn-primary" text="%btn.add" />
                           <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" text="%btn.refresh" />
                        </HBox>
                     </HBox>

                     <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" styleClass="filter-scroll" vbarPolicy="NEVER">
                        <content>
                           <HBox fx:id="filterChipContainer" spacing="8.0" styleClass="filter-chip-container" />
                        </content>
                     </ScrollPane>

                     <StackPane styleClass="table-card-wrapper" VBox.vgrow="ALWAYS">
                        <VBox spacing="0" styleClass="card-container" VBox.vgrow="ALWAYS">
                           <TableView fx:id="inventoryTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
                              <columns>
                                 <TableColumn fx:id="colPartName" minWidth="140.0" prefWidth="180.0" text="%table.partname" />
                                 <TableColumn fx:id="colMeta" minWidth="100.0" prefWidth="120.0" text="Marka / Kategori" />
                                 <TableColumn fx:id="colQuantity" minWidth="70.0" prefWidth="80.0" text="%table.quantity" />
                                 <TableColumn fx:id="colDistribution" minWidth="120.0" prefWidth="140.0" text="%table.distribution" />
                                 <TableColumn fx:id="colBuyPrice" minWidth="80.0" prefWidth="90.0" text="%table.buyprice" />
                                 <TableColumn fx:id="colSellPrice" minWidth="80.0" prefWidth="90.0" text="%table.sellprice" />
                                 <TableColumn fx:id="colCriticalLevel" minWidth="70.0" prefWidth="80.0" text="%table.critical" />
                                 <TableColumn fx:id="colActions" minWidth="100.0" prefWidth="110.0" text="%table.actions" />
                              </columns>
                              <columnResizePolicy>
                                 <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                              </columnResizePolicy>
                              <placeholder>
                                 <VBox alignment="CENTER" spacing="8.0" styleClass="empty-state">
                                    <Label styleClass="empty-state-title" text="Stok kaydı bulunamadı" />
                                    <Label styleClass="empty-state-subtitle" text="Yeni parça ekleyin veya filtreyi değiştirin." />
                                 </VBox>
                              </placeholder>
                           </TableView>
                        </VBox>
                        <VBox fx:id="emptyStateBox" alignment="CENTER" managed="false" spacing="8.0" styleClass="empty-state" visible="false">
                           <Label styleClass="empty-state-title" text="Bu filtrede sonuç yok" />
                           <Label styleClass="empty-state-subtitle" text="Farklı bir filtre seçmeyi deneyin." />
                        </VBox>
                     </StackPane>
                  </VBox>
               </content>
            </Tab>
            <Tab text="%inventory.tab.vehicle_stocks">
               <content>
                  <VBox spacing="12.0">
                     <padding>
                        <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
                     </padding>
                     <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="filter-bar">
                        <Label text="%vehicle_stock.filter_by_vehicle" />
                        <ComboBox fx:id="vehicleFilterComboBox" prefWidth="250.0" promptText="%vehicle_stock.all_vehicles" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleTransferStock" styleClass="btn-success" text="%vehicle_stock.transfer" />
                        <Button mnemonicParsing="false" onAction="#handleRefreshVehicleStocks" styleClass="btn-secondary" text="%btn.refresh" />
                     </HBox>
                     <VBox spacing="0" styleClass="card-container" VBox.vgrow="ALWAYS">
                        <TableView fx:id="vehicleStocksTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colVehiclePlate" prefWidth="150.0" text="%vehicle.license_plate" />
                              <TableColumn fx:id="colInventoryName" prefWidth="200.0" text="%inventory.part_name" />
                              <TableColumn fx:id="colStockQuantity" prefWidth="100.0" text="%table.quantity" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </VBox>
                  </VBox>
               </content>
            </Tab>
         </tabs>
      </TabPane>
   </children>
</VBox>
