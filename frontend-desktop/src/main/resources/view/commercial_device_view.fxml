<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:controller="com.pusula.desktop.controller.CommercialDeviceViewController"
      spacing="16.0" styleClass="page-view" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="page-header">
        <Label styleClass="page-header-title" text="%commercial.title" HBox.hgrow="ALWAYS" />
        <Button fx:id="btnAdd" onAction="#handleAdd" styleClass="btn-success" text="%commercial.add" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="filter-bar">
        <VBox spacing="5.0">
            <Label styleClass="field-label" text="%commercial.device_type" />
            <ComboBox fx:id="cmbDeviceType" prefWidth="150.0" promptText="Tümü" />
        </VBox>
        <VBox spacing="5.0">
            <Label styleClass="field-label" text="%commercial.brand" />
            <ComboBox fx:id="cmbBrand" prefWidth="150.0" promptText="Tümü" />
        </VBox>
        <VBox spacing="5.0">
            <Label styleClass="field-label" text="%commercial.btu" />
            <ComboBox fx:id="cmbBtu" prefWidth="120.0" promptText="Tümü" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#handleClearFilters" styleClass="btn-secondary" text="Filtreleri Temizle" />
    </HBox>

    <TableView fx:id="devicesTable" styleClass="premium-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colBrand" prefWidth="120.0" text="%commercial.brand" />
            <TableColumn fx:id="colModel" prefWidth="150.0" text="%commercial.model" />
            <TableColumn fx:id="colType" prefWidth="100.0" text="%commercial.device_type" />
            <TableColumn fx:id="colBtu" prefWidth="80.0" text="%commercial.btu" />
            <TableColumn fx:id="colGas" prefWidth="80.0" text="%commercial.gas" />
            <TableColumn fx:id="colQuantity" prefWidth="80.0" text="%commercial.quantity" />
            <TableColumn fx:id="colSellingPrice" prefWidth="100.0" text="%commercial.selling_price" />
            <TableColumn fx:id="colBuyingPrice" prefWidth="100.0" text="%commercial.buying_price" />
            <TableColumn fx:id="colProfit" prefWidth="100.0" text="%commercial.profit" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Button fx:id="btnEdit" onAction="#handleEdit" styleClass="btn-primary" text="%commercial.edit" />
        <Button fx:id="btnDelete" onAction="#handleDelete" styleClass="btn-danger" text="%commercial.delete" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="btnSell" onAction="#handleSell" styleClass="btn-purple" text="%commercial.sell" />
    </HBox>
</VBox>
