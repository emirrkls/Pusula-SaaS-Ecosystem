<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720.0" prefWidth="1200.0" styleClass="app-shell" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pusula.desktop.controller.MainDashboardController">
   <left>
      <VBox styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <VBox styleClass="sidebar-brand">
               <children>
                  <Label styleClass="sidebar-brand-title" text="Pusula" />
                  <Label styleClass="sidebar-brand-subtitle" text="Servis Yönetim Platformu" />
               </children>
            </VBox>
            <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
               <content>
                  <VBox styleClass="sidebar-nav">
                     <children>
                        <Button fx:id="navDashboard" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showDashboard" styleClass="nav-button" text="%menu.dashboard" />
                        <Button fx:id="navTickets" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showServiceManagement" styleClass="nav-button" text="%menu.tickets" />
                        <Button fx:id="navInventory" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showInventory" styleClass="nav-button" text="%menu.inventory" />
                        <Button fx:id="navCustomers" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showCustomers" styleClass="nav-button" text="%menu.customers" />
                        <Button fx:id="btnCommercial" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showCommercialDevices" styleClass="nav-button" text="%menu.commercial" />
                        <Button fx:id="btnProposals" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showProposals" styleClass="nav-button" text="Teklifler" />
                        <Button fx:id="btnFinance" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showFinance" styleClass="nav-button" text="%menu.finance" />
                        <Button fx:id="btnSettings" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showSettings" styleClass="nav-button" text="%menu.settings" />
                        <Button fx:id="btnActivityLog" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#showActivityLog" styleClass="nav-button" text="%menu.activity_log" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            <VBox styleClass="sidebar-footer">
               <children>
                  <HBox styleClass="user-profile">
                     <children>
                        <Label fx:id="userAvatarLabel" styleClass="user-avatar" text="P" />
                        <VBox spacing="2.0">
                           <children>
                              <Label fx:id="userLabel" styleClass="user-name" text="Kullanıcı" />
                              <Label fx:id="userRoleLabel" styleClass="user-role" text="Admin" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" styleClass="nav-button-danger" text="%common.logout" />
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <VBox styleClass="content-shell" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-bar">
               <children>
                  <VBox spacing="2.0">
                     <children>
                        <Label fx:id="pageTitleLabel" styleClass="page-title" text="%menu.dashboard" />
                        <Label fx:id="pageSubtitleLabel" styleClass="page-subtitle" text="" />
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Button fx:id="btnThemeToggle" mnemonicParsing="false" onAction="#toggleTheme" styleClass="icon-button" />
               </children>
            </HBox>
            <StackPane fx:id="contentArea" styleClass="content-area" VBox.vgrow="ALWAYS" />
         </children>
      </VBox>
   </center>
</BorderPane>
