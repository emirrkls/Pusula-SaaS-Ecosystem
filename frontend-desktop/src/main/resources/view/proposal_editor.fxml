<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.ProposalEditorController"
      prefHeight="700" prefWidth="900" spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label fx:id="titleLabel" styleClass="dialog-title" text="Yeni Teklif"/>
    </HBox>
    <Separator/>

    <GridPane hgap="15" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="15"/>
            <ColumnConstraints percentWidth="35"/>
            <ColumnConstraints percentWidth="15"/>
            <ColumnConstraints percentWidth="35"/>
        </columnConstraints>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="field-label" text="Başlık:"/>
        <TextField fx:id="titleField" GridPane.columnIndex="1" GridPane.columnSpan="3" GridPane.rowIndex="0"
                   promptText="Teklif Başlığı (opsiyonel)"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="field-label" text="Müşteri:"/>
        <HBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="5">
            <ComboBox fx:id="customerComboBox" prefWidth="200"/>
            <Button onAction="#handleAddCustomer" styleClass="btn-secondary" text="+"/>
        </HBox>
        <Label GridPane.columnIndex="2" GridPane.rowIndex="1" styleClass="field-label" text="Hazırlayan:"/>
        <ComboBox fx:id="preparedByComboBox" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="250"/>
        <Label GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="field-label" text="Geçerlilik:"/>
        <DatePicker fx:id="validUntilPicker" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="200"/>
        <Label GridPane.columnIndex="2" GridPane.rowIndex="2" styleClass="field-label" text="Durum:"/>
        <ComboBox fx:id="statusComboBox" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="250"/>
    </GridPane>

    <Label styleClass="section-title" text="Kalemler"/>
    <TableView fx:id="itemsTable" prefHeight="200" styleClass="premium-table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colItemDesc" prefWidth="300" text="Açıklama"/>
            <TableColumn fx:id="colItemQty" prefWidth="80" text="Adet"/>
            <TableColumn fx:id="colItemCost" prefWidth="100" text="Maliyet"/>
            <TableColumn fx:id="colItemPrice" prefWidth="100" text="Birim Fiyat"/>
            <TableColumn fx:id="colItemTotal" prefWidth="100" text="Tutar"/>
            <TableColumn fx:id="colItemActions" prefWidth="60" text=""/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <ComboBox fx:id="sourceTypeComboBox" prefWidth="100" promptText="Kaynak"/>
        <ComboBox fx:id="sourceItemComboBox" editable="true" prefWidth="220" promptText="Cihaz/Açıklama"/>
        <TextField fx:id="itemQtyField" prefWidth="60" promptText="Adet"/>
        <CurrencyTextField fx:id="itemCostField" prefWidth="80" promptText="Maliyet"/>
        <CurrencyTextField fx:id="itemPriceField" prefWidth="80" promptText="Fiyat"/>
        <Button onAction="#handleAddItem" styleClass="btn-success" text="+ Ekle"/>
    </HBox>
    <Label styleClass="hint-label" text="💡 Kaynak: Cihaz seçin veya Hizmet için açıklama yazın"/>
    <Separator/>

    <HBox alignment="CENTER_RIGHT" spacing="30">
        <VBox alignment="TOP_RIGHT" spacing="5">
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label text="Ara Toplam:"/>
                <Label fx:id="subtotalLabel" styleClass="field-value" text="0,00 ₺"/>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label text="KDV %:"/>
                <CurrencyTextField fx:id="taxRateField" prefWidth="50" text="20"/>
                <Label fx:id="taxAmountLabel" text="0,00 ₺"/>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label text="İndirim:"/>
                <CurrencyTextField fx:id="discountField" prefWidth="80" text="0"/>
            </HBox>
            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Label styleClass="section-title" text="TOPLAM:"/>
                <Label fx:id="totalLabel" styleClass="amount-highlight" text="0,00 ₺"/>
            </HBox>
        </VBox>
        <VBox fx:id="profitBox" alignment="TOP_RIGHT" spacing="5" styleClass="profit-panel">
            <Label styleClass="field-label" text="MALİYET ANALİZİ"/>
            <HBox spacing="10">
                <Label text="Toplam Maliyet:"/>
                <Label fx:id="totalCostLabel" styleClass="amount-danger" text="0,00 ₺"/>
            </HBox>
            <HBox spacing="10">
                <Label text="Kar:"/>
                <Label fx:id="profitLabel" styleClass="amount-highlight" text="0,00 ₺"/>
            </HBox>
        </VBox>
    </HBox>

    <Label styleClass="field-label" text="Notlar:"/>
    <TextArea fx:id="noteArea" prefHeight="80" wrapText="true"/>
    <Separator/>

    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button onAction="#handleCancel" styleClass="btn-secondary" text="İptal"/>
        <Button onAction="#handleSave" styleClass="btn-primary" text="Kaydet"/>
    </HBox>
</VBox>
