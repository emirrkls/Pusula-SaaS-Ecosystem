<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.pusula.desktop.util.CurrencyTextField?>

<VBox fx:controller="com.pusula.desktop.controller.InventoryDialogController"
      spacing="15.0" styleClass="dialog-root"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <Label fx:id="titleLabel" styleClass="dialog-title" text="%inventory.form.title.add" />
   <VBox spacing="5.0">
      <Label styleClass="field-label" text="%inventory.form.partname" />
      <TextField fx:id="partNameField" promptText="e.g. AC Filter" />
   </VBox>
   <HBox spacing="15.0">
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="%inventory.form.quantity" />
         <TextField fx:id="quantityField" promptText="0" />
      </VBox>
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="%inventory.form.critical" />
         <TextField fx:id="criticalLevelField" promptText="5" />
      </VBox>
   </HBox>
   <HBox spacing="15.0">
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="%inventory.form.buyprice" />
         <CurrencyTextField fx:id="buyPriceField" promptText="0,00" />
      </VBox>
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="%inventory.form.sellprice" />
         <CurrencyTextField fx:id="sellPriceField" promptText="0,00" />
      </VBox>
   </HBox>
   <HBox spacing="15.0">
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="%inventory.brand" />
         <TextField fx:id="brandField" promptText="e.g. Bosch, Samsung" />
      </VBox>
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="%inventory.category" />
         <TextField fx:id="categoryField" promptText="e.g. Filtre, Motor" />
      </VBox>
   </HBox>
   <HBox spacing="15.0">
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="Depoda" />
         <TextField fx:id="warehouseQtyField" promptText="0" />
      </VBox>
      <VBox HBox.hgrow="ALWAYS" spacing="5.0">
         <Label styleClass="field-label" text="Araçlarda" />
         <TextField fx:id="vehicleQtyField" editable="false" promptText="0" styleClass="readonly-field" />
      </VBox>
   </HBox>
   <VBox fx:id="vehicleDistributionBox" managed="false" spacing="5.0" visible="false">
      <Label styleClass="field-label" text="Araç Dağılımı:" />
      <Label fx:id="vehicleDistributionLabel" styleClass="muted-label" text="" />
   </VBox>
   <HBox alignment="CENTER_RIGHT" spacing="10.0">
      <VBox.margin>
         <Insets top="10.0" />
      </VBox.margin>
      <Button mnemonicParsing="false" onAction="#handleCancel" styleClass="btn-secondary" text="%btn.cancel" />
      <Button defaultButton="true" mnemonicParsing="false" onAction="#handleSave" styleClass="btn-success" text="%inventory.form.save" />
   </HBox>
</VBox>
