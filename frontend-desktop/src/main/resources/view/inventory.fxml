<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pusula.desktop.controller.InventoryController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="%inventory.title">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      
      <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
         <tabs>
            <!-- Stock Tab -->
            <Tab text="%inventory.tab.stock">
               <content>
                  <VBox spacing="15.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <javafx.scene.control.TextField fx:id="searchField" promptText="%inventory.search" prefWidth="200.0" />
                              <Button mnemonicParsing="false" onAction="#handleExportPdf" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="%btn.export" />
                              <Button mnemonicParsing="false" onAction="#handleAddItem" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="%btn.add" />
                              <Button mnemonicParsing="false" onAction="#handleRefresh" text="%btn.refresh" />
                           </children>
                        </HBox>
                        <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colPartName" prefWidth="180.0" text="%table.partname" />
                            <TableColumn fx:id="colQuantity" prefWidth="80.0" text="%table.quantity" />
                            <TableColumn fx:id="colDistribution" prefWidth="120.0" text="%table.distribution" />
                              <TableColumn fx:id="colBuyPrice" prefWidth="80.0" text="%table.buyprice" />
                              <TableColumn fx:id="colSellPrice" prefWidth="80.0" text="%table.sellprice" />
                              <TableColumn fx:id="colCriticalLevel" prefWidth="80.0" text="%table.critical" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </content>
            </Tab>
            
            <!-- Vehicle Stocks Tab -->
            <Tab text="%inventory.tab.vehicle_stocks">
               <content>
                  <VBox spacing="15.0">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <Label text="%vehicle_stock.filter_by_vehicle" />
                              <ComboBox fx:id="vehicleFilterComboBox" prefWidth="250.0" promptText="%vehicle_stock.all_vehicles" />
                              <Button mnemonicParsing="false" onAction="#handleTransferStock" 
                                      style="-fx-background-color: #27ae60; -fx-text-fill: white;" 
                                      text="%vehicle_stock.transfer" />
                              <Button mnemonicParsing="false" onAction="#handleRefreshVehicleStocks" text="%btn.refresh" />
                           </children>
                        </HBox>
                        <TableView fx:id="vehicleStocksTable" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colVehiclePlate" prefWidth="150.0" text="%vehicle.license_plate" />
                            <TableColumn fx:id="colInventoryName" prefWidth="200.0" text="%inventory.part_name" />
                              <TableColumn fx:id="colStockQuantity" prefWidth="100.0" text="%table.quantity" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
               </content>
            </Tab>
         </tabs>
      </TabPane>
   </children>
</VBox>
